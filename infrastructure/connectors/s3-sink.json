{
  "name": "s3-sink",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "1",
    "topics": "postgres.public.customers,postgres.public.cards,postgres.public.transactions,mongo.banking_events.login_events,mongo.banking_events.fraud_events,mongo.banking_events.audit_logs,mongo.banking_events.notification_logs,mongo.banking_events.device_events",
    "s3.bucket.name": "banking-lakehouse",
    "s3.region": "us-east-1",
    "s3.part.size": "5242880",
    "flush.size": "2",
    "rotate.schedule.interval.ms": "5000",
    "timezone": "UTC",
    "store.url": "http://minio:9000",
    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",
    "partitioner.class": "io.confluent.connect.storage.partitioner.TimeBasedPartitioner",
    "path.format": "'year'=YYYY/'month'=MM/'day'=dd",
    "partition.duration.ms": "86400000",
    "timestamp.extractor": "Wallclock",
    "locale": "en-US",
    "timezone": "UTC",
    "schema.compatibility": "NONE",
    "aws.access.key.id": "minio_admin",
    "aws.secret.access.key": "minio_password",
    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry:8081"

  }
}
